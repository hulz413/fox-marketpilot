ENVIRONMENT=local
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

DATABASE_URL=postgresql+psycopg://marketpilot:marketpilot@localhost:5432/marketpilot
REDIS_URL=redis://localhost:6379/0

S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=marketpilot
S3_ACCESS_KEY_ID=marketpilot
S3_SECRET_ACCESS_KEY=marketpilot-secret

LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=marketpilot-dev
LANGSMITH_ENDPOINT=
LANGSMITH_WORKSPACE_ID=

TAVILY_API_KEY=

LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash

RAG_RETRIEVAL_ENABLED=true
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
